@model GoMath.Models.FactorialViewModel
@{
    ViewData["Title"] = "Tính giai thừa";
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <span>Tính giai thừa</span>
        </div>
        <div class="page-icon"><i class="bi bi-exclamation-circle-fill"></i></div>
        <h1>Tính giai thừa n!</h1>
        <p>Tính n! với khai triển đầy đủ dạng tích</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-lg-5">
                <div class="gm-form-card">
                    <h5 class="fw-700 mb-4 text-white">Nhập số n</h5>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label">n (từ 0 đến 20)</label>
                            <input type="number" class="form-control" name="Number" value="@Model.Number" min="0" max="20" placeholder="Ví dụ: 5" style="font-size:2rem;text-align:center;font-weight:700;" />
                        </div>
                        <button type="submit" class="btn-gm-primary w-100">
                            <i class="bi bi-calculator me-2"></i>Tính giai thừa
                        </button>
                    </form>
                    <div class="mt-4" style="background:rgba(255,255,255,0.04);border-radius:10px;padding:16px;text-align:center;">
                        <div style="font-size:0.8rem;color:#94a3b8;margin-bottom:6px;">Định nghĩa</div>
                        <div style="color:#cbd5e1;font-size:0.9rem;">
                            \[ n! = n \times (n-1) \times \cdots \times 2 \times 1 \]
                        </div>
                        <div style="color:#64748b;font-size:0.82rem;margin-top:8px;">Quy ước: 0! = 1</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                @if (Model.Result != null)
                {
                    <div class="result-box mb-4 text-center">
                        <div class="result-label"><i class="bi bi-check2-circle me-1"></i>Kết quả</div>
                        <div style="font-size:2.5rem;font-weight:800;color:var(--primary);word-break:break-all;">
                            @Model.Number! = @Model.Result
                        </div>
                    </div>

                    <div class="gm-form-card">
                        <h6 class="fw-700 mb-3" style="color:#94a3b8;text-transform:uppercase;font-size:0.8rem;letter-spacing:1px;">Khai triển</h6>
                        <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:16px;word-break:break-all;color:#cbd5e1;font-size:0.92rem;line-height:1.8;">
                            @Model.Expansion
                        </div>
                    </div>
                }
                else
                {
                    <div class="gm-form-card text-center py-5">
                        <i class="bi bi-exclamation-lg" style="font-size:3rem;color:#334155;"></i>
                        <p class="mt-3" style="color:#475569;">Nhập giá trị n để tính giai thừa</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
