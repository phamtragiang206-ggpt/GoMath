@model GoMath.Models.GradeViewModel
@{
    ViewData["Title"] = "Tính điểm trung bình";
    string rankClass = Model.Rank switch {
        "Tốt" => "rank-tot",
        "Khá" => "rank-kha",
        "Đạt" => "rank-dat",
        _ => "rank-chua"
    };
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <span>Tính điểm TB & xếp loại</span>
        </div>
        <div class="page-icon"><i class="bi bi-award-fill"></i></div>
        <h1>Tính điểm TB & xếp loại</h1>
        <p>Tính điểm trung bình môn và xếp loại học lực theo thang điểm 10</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-lg-5">
                <div class="gm-form-card">
                    <h5 class="fw-700 mb-4 text-white">Nhập điểm</h5>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Điểm thường xuyên <span style="color:#94a3b8;font-size:0.8rem;">(hệ số 1)</span></label>
                            <input type="number" class="form-control" name="RegularScore" value="@Model.RegularScore" step="0.1" min="0" max="10" placeholder="0 - 10" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Điểm giữa kỳ <span style="color:#94a3b8;font-size:0.8rem;">(hệ số 2)</span></label>
                            <input type="number" class="form-control" name="MidtermScore" value="@Model.MidtermScore" step="0.1" min="0" max="10" placeholder="0 - 10" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Điểm cuối kỳ <span style="color:#94a3b8;font-size:0.8rem;">(hệ số 3)</span></label>
                            <input type="number" class="form-control" name="FinalScore" value="@Model.FinalScore" step="0.1" min="0" max="10" placeholder="0 - 10" />
                        </div>

                        <!-- Formula -->
                        <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:14px;margin-bottom:20px;text-align:center;">
                            <div style="font-size:0.8rem;color:#94a3b8;margin-bottom:6px;">Công thức</div>
                            <div style="color:#cbd5e1;font-size:0.92rem;">
                                \[ \bar{X} = \frac{1 \cdot \text{TX} + 2 \cdot \text{GK} + 3 \cdot \text{CK}}{6} \]
                            </div>
                        </div>

                        <button type="submit" class="btn-gm-primary w-100">
                            <i class="bi bi-calculator me-2"></i>Tính điểm
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-5">
                @if (Model.Average.HasValue)
                {
                    <div class="result-box mb-4 text-center">
                        <div class="result-label"><i class="bi bi-award me-1"></i>Điểm trung bình môn</div>
                        <div class="result-value" style="font-size:3rem;">@Model.Average?.ToString("F2")</div>
                        <div class="mt-3">
                            <span class="rank-badge @rankClass" style="font-size:1rem;padding:8px 24px;">@Model.Rank</span>
                        </div>
                    </div>

                    <div class="gm-form-card">
                        <h6 class="fw-700 mb-3" style="color:#94a3b8;text-transform:uppercase;font-size:0.8rem;letter-spacing:1px;">Bảng xếp loại</h6>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var (name, min, cls) in new[] { ("Tốt", "≥ 8.0", "rank-tot"), ("Khá", "6.5 – 7.9", "rank-kha"), ("Đạt", "5.0 – 6.4", "rank-dat"), ("Chưa đạt", "< 5.0", "rank-chua") })
                            {
                                <div class="d-flex align-items-center justify-content-between" style="padding:10px;background:rgba(255,255,255,0.03);border-radius:8px;@(Model.Rank == name ? "border:1px solid rgba(34,197,94,0.3);" : "")">
                                    <span class="rank-badge @cls">@name</span>
                                    <span style="color:#94a3b8;font-size:0.88rem;">@min</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="gm-form-card text-center py-5">
                        <i class="bi bi-bar-chart-fill" style="font-size:3rem;color:#334155;"></i>
                        <p class="mt-3" style="color:#475569;">Nhập điểm để tính kết quả</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
