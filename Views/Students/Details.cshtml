@model GoMath.Models.Student
@{
    ViewData["Title"] = "Chi tiết học sinh";
    string rankCls = Model.GetRank() switch {
        "Tốt" => "rank-tot",
        "Khá" => "rank-kha",
        "Đạt" => "rank-dat",
        _ => "rank-chua"
    };
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <a asp-controller="Students" asp-action="Index">Quản lý học sinh</a> /
            <span>Chi tiết</span>
        </div>
        <div class="page-icon" style="background:linear-gradient(135deg,#3b82f6,#1d4ed8);"><i class="bi bi-person-badge-fill"></i></div>
        <h1>@Model.FullName</h1>
        <p>@Model.StudentCode · Lớp @Model.ClassName</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-lg-5">
                <div class="gm-form-card">
                    <h5 class="fw-700 mb-4 text-white">Thông tin chi tiết</h5>
                    <div class="d-flex flex-column gap-3">
                        @foreach (var (label, value) in new[] {
                            ("Mã học sinh", Model.StudentCode),
                            ("Họ và tên", Model.FullName),
                            ("Ngày sinh", Model.DateOfBirth.ToString("dd/MM/yyyy")),
                            ("Lớp", Model.ClassName)
                        })
                        {
                            <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,0.06);">
                                <span style="color:#64748b;font-size:0.9rem;">@label</span>
                                <span style="color:white;font-weight:600;">@value</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <span style="color:#64748b;font-size:0.9rem;">Điểm trung bình</span>
                            <div class="text-end">
                                <div style="font-size:1.8rem;font-weight:800;color:white;">@Model.AverageScore.ToString("F2")</div>
                                <span class="rank-badge @rankCls">@Model.GetRank()</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-gm-primary flex-grow-1">
                            <i class="bi bi-pencil me-1"></i>Chỉnh sửa
                        </a>
                        <a asp-action="Index" class="btn-gm-secondary">Quay lại</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
