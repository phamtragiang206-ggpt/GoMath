@model List<GoMath.Models.Student>
@{
    ViewData["Title"] = "Quản lý học sinh";
    string? searchName = ViewBag.SearchName as string;
    string? searchClass = ViewBag.SearchClass as string;
    List<string> allClasses = ViewBag.AllClasses as List<string> ?? new();
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <span>Quản lý học sinh</span>
        </div>
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-icon" style="background:linear-gradient(135deg,#a855f7,#7c3aed);"><i class="bi bi-people-fill"></i></div>
                <h1>Quản lý học sinh</h1>
                <p>Danh sách, thêm, sửa, xóa và tìm kiếm thông tin học sinh</p>
            </div>
            <a asp-action="Create" class="btn-gm-primary align-self-end" style="margin-bottom:4px;">
                <i class="bi bi-plus-lg me-1"></i>Thêm học sinh
            </a>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert-gm-success mb-4 auto-dismiss d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["Success"]
            </div>
        }

        <!-- Search & Filter -->
        <div class="gm-form-card mb-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-sm-5">
                    <label class="form-label">Tìm theo tên</label>
                    <input type="text" name="searchName" class="form-control" value="@searchName" placeholder="Nhập họ tên..." />
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Lọc theo lớp</label>
                    <select name="searchClass" class="form-select">
                        <option value="">-- Tất cả lớp --</option>
                        @foreach (var cls in allClasses)
                        {
                            <option value="@cls" selected="@(searchClass == cls)">@cls</option>
                        }
                    </select>
                </div>
                <div class="col-sm-3 d-flex gap-2">
                    <button type="submit" class="btn-gm-primary flex-grow-1">
                        <i class="bi bi-search me-1"></i>Tìm
                    </button>
                    @if (!string.IsNullOrEmpty(searchName) || !string.IsNullOrEmpty(searchClass))
                    {
                        <a asp-action="Index" class="btn-gm-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="gm-form-card p-0" style="overflow:hidden;">
            <div style="padding:20px 24px 0;">
                <div class="d-flex align-items-center justify-content-between">
                    <span style="font-size:0.85rem;color:#64748b;">
                        Hiển thị <strong style="color:#94a3b8;">@Model.Count</strong> học sinh
                        @if (!string.IsNullOrEmpty(searchName) || !string.IsNullOrEmpty(searchClass))
                        {
                            <span> (đã lọc)</span>
                        }
                    </span>
                </div>
            </div>

            @if (Model.Any())
            {
                <div style="overflow-x:auto;padding:16px 0;">
                    <table class="gm-table">
                        <thead>
                            <tr>
                                <th>Mã HS</th>
                                <th>Họ và tên</th>
                                <th>Ngày sinh</th>
                                <th>Lớp</th>
                                <th>Điểm TB</th>
                                <th>Xếp loại</th>
                                <th style="text-align:right;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                string rankCls = s.GetRank() switch {
                                    "Tốt" => "rank-tot",
                                    "Khá" => "rank-kha",
                                    "Đạt" => "rank-dat",
                                    _ => "rank-chua"
                                };
                                <tr>
                                    <td style="font-family:monospace;color:#94a3b8;font-size:0.85rem;">@s.StudentCode</td>
                                    <td style="font-weight:600;color:white;">@s.FullName</td>
                                    <td style="color:#94a3b8;">@s.DateOfBirth.ToString("dd/MM/yyyy")</td>
                                    <td><span class="class-tag">@s.ClassName</span></td>
                                    <td style="font-weight:700;color:white;">@s.AverageScore.ToString("F2")</td>
                                    <td><span class="rank-badge @rankCls">@s.GetRank()</span></td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-end">
                                            <a asp-action="Details" asp-route-id="@s.Id"
                                                style="padding:5px 12px;background:rgba(59,130,246,0.15);color:#60a5fa;border-radius:8px;font-size:0.82rem;font-weight:600;text-decoration:none;"
                                                title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@s.Id"
                                                style="padding:5px 12px;background:rgba(234,179,8,0.15);color:var(--accent);border-radius:8px;font-size:0.82rem;font-weight:600;text-decoration:none;"
                                                title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@s.Id"
                                                style="padding:5px 12px;background:rgba(239,68,68,0.15);color:#f87171;border-radius:8px;font-size:0.82rem;font-weight:600;text-decoration:none;"
                                                title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search" style="font-size:2.5rem;color:#334155;"></i>
                    <p class="mt-3" style="color:#475569;">Không tìm thấy học sinh nào</p>
                    <a asp-action="Index" class="card-link">Xóa bộ lọc</a>
                </div>
            }
        </div>
    </div>
</section>
