@model GoMath.Models.Student
@{
    ViewData["Title"] = "Thêm học sinh";
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <a asp-controller="Students" asp-action="Index">Quản lý học sinh</a> /
            <span>Thêm mới</span>
        </div>
        <div class="page-icon" style="background:linear-gradient(135deg,#22c55e,#16a34a);"><i class="bi bi-person-plus-fill"></i></div>
        <h1>Thêm học sinh mới</h1>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="gm-form-card">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Mã học sinh</label>
                            <input type="text" class="form-control @(ViewData.ModelState["StudentCode"]?.Errors.Any() == true ? "is-invalid" : "")"
                                name="StudentCode" value="@Model.StudentCode" placeholder="HS001" />
                            @if (ViewData.ModelState["StudentCode"]?.Errors.Any() == true)
                            {
                                <div class="invalid-feedback" style="color:#f87171;font-size:0.82rem;margin-top:4px;">
                                    @ViewData.ModelState["StudentCode"]!.Errors.First().ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Họ và tên</label>
                            <input type="text" class="form-control" name="FullName" value="@Model.FullName" placeholder="Nguyễn Văn An" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ngày sinh</label>
                            <input type="date" class="form-control" name="DateOfBirth" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lớp</label>
                            <input type="text" class="form-control" name="ClassName" value="@Model.ClassName" placeholder="10A1" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Điểm trung bình tích lũy <span style="color:#94a3b8;">(0.00 – 10.00)</span></label>
                            <input type="number" class="form-control" name="AverageScore" value="@Model.AverageScore" step="0.01" min="0" max="10" placeholder="8.50" />
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-gm-primary flex-grow-1">
                                <i class="bi bi-check-lg me-1"></i>Lưu học sinh
                            </button>
                            <a asp-action="Index" class="btn-gm-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
