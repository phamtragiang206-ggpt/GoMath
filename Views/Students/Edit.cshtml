@model GoMath.Models.Student
@{
    ViewData["Title"] = "Sửa thông tin học sinh";
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <a asp-controller="Students" asp-action="Index">Quản lý học sinh</a> /
            <span>Chỉnh sửa</span>
        </div>
        <div class="page-icon" style="background:linear-gradient(135deg,#eab308,#ca8a04);"><i class="bi bi-pencil-fill"></i></div>
        <h1>Chỉnh sửa thông tin</h1>
        <p>@Model.FullName – @Model.StudentCode</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="gm-form-card">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label">Mã học sinh</label>
                            <input type="text" class="form-control" name="StudentCode" value="@Model.StudentCode" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Họ và tên</label>
                            <input type="text" class="form-control" name="FullName" value="@Model.FullName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ngày sinh</label>
                            <input type="date" class="form-control" name="DateOfBirth" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Lớp</label>
                            <input type="text" class="form-control" name="ClassName" value="@Model.ClassName" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Điểm trung bình tích lũy</label>
                            <input type="number" class="form-control" name="AverageScore" value="@Model.AverageScore" step="0.01" min="0" max="10" />
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-gm-primary flex-grow-1">
                                <i class="bi bi-check-lg me-1"></i>Cập nhật
                            </button>
                            <a asp-action="Index" class="btn-gm-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
