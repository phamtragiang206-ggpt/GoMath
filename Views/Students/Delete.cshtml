@model GoMath.Models.Student
@{
    ViewData["Title"] = "Xóa học sinh";
}

<section class="page-header">
    <div class="container">
        <div class="gm-breadcrumb mb-3">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a> /
            <a asp-controller="Students" asp-action="Index">Quản lý học sinh</a> /
            <span>Xóa</span>
        </div>
        <div class="page-icon" style="background:linear-gradient(135deg,#ef4444,#b91c1c);"><i class="bi bi-trash-fill"></i></div>
        <h1>Xác nhận xóa</h1>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="delete-confirm-card mb-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div style="width:48px;height:48px;background:rgba(239,68,68,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#f87171;font-size:1.3rem;">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;color:white;font-size:1.1rem;">Bạn chắc chắn muốn xóa?</div>
                            <div style="color:#94a3b8;font-size:0.88rem;">Hành động này không thể hoàn tác</div>
                        </div>
                    </div>

                    <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:16px;margin-bottom:20px;">
                        <div class="row g-2" style="font-size:0.9rem;">
                            <div class="col-4" style="color:#64748b;">Mã học sinh:</div>
                            <div class="col-8" style="color:white;font-weight:600;">@Model.StudentCode</div>
                            <div class="col-4" style="color:#64748b;">Họ tên:</div>
                            <div class="col-8" style="color:white;font-weight:600;">@Model.FullName</div>
                            <div class="col-4" style="color:#64748b;">Lớp:</div>
                            <div class="col-8" style="color:white;">@Model.ClassName</div>
                            <div class="col-4" style="color:#64748b;">Điểm TB:</div>
                            <div class="col-8" style="color:white;">@Model.AverageScore.ToString("F2")</div>
                        </div>
                    </div>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-3">
                            <button type="submit" style="background:linear-gradient(135deg,#ef4444,#b91c1c);border:none;color:white;font-weight:700;padding:12px 28px;border-radius:10px;flex:1;font-size:0.95rem;">
                                <i class="bi bi-trash me-1"></i>Xóa học sinh
                            </button>
                            <a asp-action="Index" class="btn-gm-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
