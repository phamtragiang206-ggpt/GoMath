<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoMath</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="https://cdn.jsdelivr.net/npm/mathjax@@3/es5/tex-mml-chtml.js" async></script>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <div class="brand-icon">
                    <i class="bi bi-calculator-fill"></i>
                </div>
                <span class="brand-text">Go<span class="brand-accent">Math</span></span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link nav-pill" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link nav-pill dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-mortarboard-fill me-1"></i>Công cụ học tập
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark border-0 shadow-lg">
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="Equation"><i class="bi bi-superscript me-2 text-warning"></i>Giải phương trình</a></li>
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="Grade"><i class="bi bi-award-fill me-2 text-warning"></i>Tính điểm TB & xếp loại</a></li>
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="Prime"><i class="bi bi-123 me-2 text-warning"></i>Kiểm tra số nguyên tố</a></li>
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="Factorial"><i class="bi bi-exclamation-circle-fill me-2 text-warning"></i>Tính giai thừa</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link nav-pill dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-lightning-fill me-1"></i>Đời sống
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark border-0 shadow-lg">
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="UnitConverter"><i class="bi bi-arrow-left-right me-2 text-info"></i>Chuyển đổi đơn vị</a></li>
                            <li><a class="dropdown-item" asp-controller="Tools" asp-action="UtilityBill"><i class="bi bi-plug-fill me-2 text-info"></i>Tính tiền điện / nước</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-pill" asp-controller="Students" asp-action="Index">
                            <i class="bi bi-people-fill me-1"></i>Quản lý học sinh
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-section mt-5">
        <div class="container">
            <div class="row align-items-center py-4">
                <div class="col-md-4 text-center text-md-start">
                    <span class="brand-text fs-5">Go<span class="brand-accent">Math</span></span>
                    <p class="text-muted small mb-0 mt-1">Hỗ trợ học tập cho học sinh THPT</p>
                </div>
                <div class="col-md-8 text-center text-md-end mt-3 mt-md-0">
                    <span class="text-muted small">© 2025 GoMath. Được xây dựng với ASP.NET Core MVC + C#</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>