@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Banner -->

<section class="hero-section">
    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <div class="hero-badge mb-3">
                    <i class="bi bi-mortarboard-fill"></i>
                    Website hỗ trợ học tập
                </div>

                <h1 class="hero-title">
                    GoMath
                    <br />
                        <span class="highlight" style="white-space: nowrap;">
                            Học Toán mỗi ngày
                        </span>
                </h1>

                <p class="hero-desc mt-4">
                    GoMath là website hỗ trợ học sinh THPT trong việc học tập và tính toán.
                    Hệ thống cung cấp các công cụ giải phương trình, tính điểm,
                    chuyển đổi đơn vị và quản lý học sinh.
                </p>

                <div class="mt-4 d-flex gap-3">

                    <a href="#features" class="btn-primary-gm">
                        <i class="bi bi-play-fill"></i>
                        Khám phá ngay
                    </a>

                    <a asp-controller="Students"
                       asp-action="Index"
                       class="btn-outline-gm">
                        <i class="bi bi-people-fill"></i>
                        Quản lý học sinh
                    </a>

                </div>

            </div>

            <div class="col-lg-6 d-none d-lg-block">

                <div class="hero-preview">

                    <div class="preview-card small-card">

                        <h6>Kết quả</h6>

                        <h4>x = 3.5</h4>

                        <small>Phương trình bậc nhất</small>

                    </div>

                    <div class="preview-card main-card">

                        <div class="d-flex align-items-center mb-3">

                            <i class="bi bi-calculator fs-3 me-2"></i>

                            <div>
                                <strong>Giải phương trình</strong>
                                <br />
                                <small>ax² + bx + c = 0</small>
                            </div>

                        </div>

                        <div class="result-box">
                            Δ = b² - 4ac = 49
                        </div>

                        <p class="mt-3 mb-0">
                            x₁ = 2 &nbsp;&nbsp; | &nbsp;&nbsp; x₂ = -1
                        </p>

                    </div>

                    <div class="preview-card small-card">

                        <h6>Xếp loại</h6>

                        <h4>8.25</h4>

                        <span class="rank-badge rank-tot">
                            Tốt
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>
    
</section>

<!-- Chức năng -->

<section id="features" class="py-5">

    ```
    <div class="container">

        <div class="text-center mb-5">

            <h2>Các chức năng chính</h2>

            <p class="text-muted">
                Website cung cấp các công cụ hỗ trợ học tập và quản lý học sinh.
            </p>

        </div>

        <!-- Công cụ học tập -->
        <h4 class="mb-4">
            <i class="bi bi-book-fill me-2"></i>
            Công cụ học tập
        </h4>

        <div class="row">

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="gm-card p-4 h-100">

                    <i class="bi bi-superscript fs-1 text-success"></i>

                    <h5 class="mt-3">
                        Giải phương trình
                    </h5>

                    <p>
                        Giải phương trình bậc nhất và bậc hai.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="Equation"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="gm-card p-4 h-100">

                    <i class="bi bi-award-fill fs-1 text-warning"></i>

                    <h5 class="mt-3">
                        Tính điểm
                    </h5>

                    <p>
                        Tính điểm trung bình và xếp loại học lực.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="Grade"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="gm-card p-4 h-100">

                    <i class="bi bi-123 fs-1 text-primary"></i>

                    <h5 class="mt-3">
                        Số nguyên tố
                    </h5>

                    <p>
                        Kiểm tra số nguyên tố.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="Prime"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="gm-card p-4 h-100">

                    <i class="bi bi-exclamation-circle-fill fs-1 text-danger"></i>

                    <h5 class="mt-3">
                        Giai thừa
                    </h5>

                    <p>
                        Tính giá trị giai thừa n!.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="Factorial"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

        </div>

        <!-- Công cụ đời sống -->
        <h4 class="mt-5 mb-4">
            <i class="bi bi-lightning-fill me-2"></i>
            Công cụ đời sống
        </h4>

        <div class="row">

            <div class="col-md-6 mb-4">
                <div class="gm-card p-4">

                    <h5>Chuyển đổi đơn vị</h5>

                    <p>
                        Hỗ trợ chuyển đổi độ dài, diện tích,
                        thể tích, khối lượng và thời gian.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="UnitConverter"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="gm-card p-4">

                    <h5>Tính tiền điện / nước</h5>

                    <p>
                        Tính chi phí điện hoặc nước theo bậc thang.
                    </p>

                    <a asp-controller="Tools"
                       asp-action="UtilityBill"
                       class="card-link">
                        Sử dụng
                    </a>

                </div>
            </div>

        </div>

        <!-- CRUD -->
        <h4 class="mt-5 mb-4">
            <i class="bi bi-people-fill me-2"></i>
            Quản lý học sinh
        </h4>

        <div class="gm-card p-4">

            <h5>Chức năng quản lý học sinh</h5>

            <p>
                Cho phép quản lý thông tin học sinh trong hệ thống.
            </p>

            <ul>
                <li>Xem danh sách học sinh</li>
                <li>Thêm học sinh mới</li>
                <li>Chỉnh sửa thông tin</li>
                <li>Xóa học sinh</li>
                <li>Tìm kiếm học sinh</li>
            </ul>

            <a asp-controller="Students"
               asp-action="Index"
               class="btn-gm-primary">
                Truy cập chức năng
            </a>

        </div>

    </div>
    ```

</section>
